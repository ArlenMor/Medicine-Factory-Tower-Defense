  m_Script: {fileID: 11500000, guid: 27bca9973e66a9a49933ae9b7d744732, type: 3}
  m_Name: LocalizationConfig
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Code.Scripts.Localization.LocalizationConfig
  Entries:
  - Key: KEY_Reward
    English: 'Reward:'
    Russian: "\u041D\u0430\u0433\u0440\u0430\u0434\u0430:"
    EnglishSprite: {fileID: 0}
    RussianSprite: {fileID: 0}
  - Key: level1Step6
    English: You can remove an unripe plant by tapping it, then tapping the trash
      button.
    Russian: "\u0422\u044B \u043C\u043E\u0436\u0435\u0448\u044C \u0443\u0434\u0430\u043B\u0438\u0442\u044C
      \u043D\u0435\u0441\u043F\u0435\u043B\u043E\u0435 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0435,
      \u043D\u0430\u0436\u0430\u0432 \u043D\u0430 \u043D\u0435\u0433\u043E, \u0430
      \u0437\u0430\u0442\u0435\u043C \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
      \u043A\u043E\u0440\u0437\u0438\u043D\u044B."
    EnglishSprite: {fileID: 0}
    RussianSprite: {fileID: 0}
  - Key: level1Step5
    English: 'Empty beds can be used to grow new plants.

      Select a plant and
      place it in a free bed'
    Russian: "\u041F\u0443\u0441\u0442\u044B\u0435 \u0433\u0440\u044F\u0434\u043A\u0438
      \u043C\u043E\u0436\u043D\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u0434\u043B\u044F \u0432\u044B\u0440\u0430\u0449\u0438\u0432\u0430\u043D\u0438\u044F
      \u043D\u043E\u0432\u044B\u0445 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0439.
      \n\u0412\u044B\u0431\u0435\u0440\u0438 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0435
      \u0438 \u043F\u043E\u043C\u0435\u0441\u0442\u0438 \u0435\u0433\u043E \u043D\u0430
      \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u0443\u044E \u0433\u0440\u044F\u0434\u043A\u0443."
    EnglishSprite: {fileID: 0}
    RussianSprite: {fileID: 0}
  - Key: level1Step4
    English: This is a crafting station. Click to create medicines in exchange for
      resources and fulfill orders.
    Russian: "\u042D\u0442\u043E \u0441\u0442\u0430\u043D\u0446\u0438\u044F \u043A\u0440\u0430\u0444\u0442\u0430.
      \u041A\u043B\u0438\u043A\u043D\u0438, \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u0442\u044C
      \u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432\u0430 \u0432 \u043E\u0431\u043C\u0435\u043D
      \u043D\u0430 \u0440\u0435\u0441\u0443\u0440\u0441\u044B \u0438 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0442\u044C
      \u0437\u0430\u043A\u0430\u0437\u044B."
    EnglishSprite: {fileID: 0}
    RussianSprite: {fileID: 0}
  - Key: level1Step3
    English: 'Your plants produce resources.

      Click on a fully grown plant
      to harvest it'
    Russian: "\u0422\u0432\u043E\u0438 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F
      \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u044F\u0442 \u0440\u0435\u0441\u0443\u0440\u0441\u044B.
      \n\u041D\u0430\u0436\u043C\u0438 \u043D\u0430 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
      \u0432\u044B\u0440\u043E\u0441\u0448\u0435\u0435 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0431\u0440\u0430\u0442\u044C \u0435\u0433\u043E."
    EnglishSprite: {fileID: 0}
    RussianSprite: {fileID: 0}
  - Key: level1Step2.5
    English: Your resources here
    Russian: "\u0422\u0432\u043E\u0438 \u0440\u0435\u0441\u0443\u0440\u0441\u044B
      \u043D\u0430\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u0437\u0434\u0435\u0441\u044C."
    EnglishSprite: {fileID: 0}
    RussianSprite: {fileID: 0}
  - Key: level1Step2
    English: 'This is the Orders Station.

      Here you can see which medicines
      need to be crafted to complete the level'
    Russian: "\u042D\u0442\u043E \u0441\u0442\u0430\u043D\u0446\u0438\u044F \u0437\u0430\u043A\u0430\u0437\u043E\u0432.
      \n\u0417\u0434\u0435\u0441\u044C \u0442\u044B \u043C\u043E\u0436\u0435\u0448\u044C
      \u0443\u0432\u0438\u0434\u0435\u0442\u044C, \u043A\u0430\u043A\u0438\u0435
      \u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432\u0430 \u043D\u0443\u0436\u043D\u043E
      \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0434\u043B\u044F \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F
      \u0443\u0440\u043E\u0432\u043D\u044F."
    EnglishSprite: {fileID: 0}
    RussianSprite: {fileID: 0}
  - Key: level1Step1
    English: Welcome to the factory. Your job is to grow plants, craft medicine,
      and keep the station running!
    Russian: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
      \u043D\u0430 \u0444\u0430\u0431\u0440\u0438\u043A\u0443. \u0422\u0432\u043E\u044F
      \u0437\u0430\u0434\u0430\u0447\u0430 \u2014 \u0432\u044B\u0440\u0430\u0449\u0438\u0432\u0430\u0442\u044C
      \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u0442\u044C
      \u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432\u0430 \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C
      \u0440\u0430\u0431\u043E\u0442\u0443 \u0441\u0442\u0430\u043D\u0446\u0438\u0438!"
    EnglishSprite: {fileID: 0}
    RussianSprite: {fileID: 0}
